COMPOSE_PROJECT_NAME=media-center-local

POSTGRES_DB=nmc
POSTGRES_USER=nmc
POSTGRES_PASSWORD=nmc_dev_password
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://nmc:nmc_dev_password@localhost:5432/nmc

REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

RABBITMQ_DEFAULT_USER=nmc
RABBITMQ_DEFAULT_PASS=nmc_dev_password
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_URL=amqp://nmc:nmc_dev_password@localhost:5672/

CHROMA_HOST=localhost
CHROMA_PORT=8001

MINIO_ROOT_USER=nmc_minio
MINIO_ROOT_PASSWORD=nmc_minio_dev_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=nmc-dev
MINIO_REGION=ru-central-1
