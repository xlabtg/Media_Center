# ============================================================================
# Пример конфигурации платформы НМЦ. Скопируйте в .env и заполните значения.
# НИКОГДА не коммитьте реальный .env с секретами — только этот шаблон.
# ============================================================================

# --- Общее ---
APP_ENV=development           # development | staging | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR | CRITICAL
APP_HOST=0.0.0.0
APP_PORT=7700

# --- База данных (PostgreSQL + SQLAlchemy async) ---
DATABASE_URL=postgresql+asyncpg://nmc:CHANGE_ME@localhost:5432/nmc

# --- Кэш и очереди ---
REDIS_URL=redis://localhost:6379/0
RABBITMQ_URL=amqp://guest:CHANGE_ME@localhost:5672/

# --- Векторная БД (ChromaDB) ---
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_SSL=false

# --- Объектное хранилище (S3 / MinIO) ---
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_BUCKET=nmc-dev
S3_REGION=ru-central-1

# --- Аутентификация и шифрование ---
JWT_SECRET=CHANGE_ME_USE_LONG_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=30
JWT_REFRESH_TTL_DAYS=14
TOTP_ISSUER=NMC
TOTP_STEP_SECONDS=30
TOTP_ALLOWED_DRIFT_STEPS=1
# Ключ шифрования токенов площадок (AES-256, 32 байта в base64/hex)
ENCRYPTION_KEY=CHANGE_ME_32_BYTES_KEY

# --- Service-to-service авторизация ---
SERVICE_NAME=api-gateway
S2S_AUTH_METHOD=                 # kubernetes_sa | rsa_key | shared_secret
S2S_SHARED_SECRET=CHANGE_ME_S2S_SHARED_SECRET
S2S_REPLAY_WINDOW_SECONDS=300
S2S_TOKEN_TTL_SECONDS=60
K8S_AUTH_ENABLED=true
S2S_K8S_TOKEN_PATH=/var/run/secrets/kubernetes.io/serviceaccount/token
S2S_AUDIENCE=nmc-services
S2S_K8S_ISSUER=
S2S_K8S_TOKENREVIEW_URL=
S2S_K8S_TOKENREVIEW_TOKEN_PATH=
S2S_K8S_TOKENREVIEW_TIMEOUT_SECONDS=2
S2S_K8S_CA_PATH=/var/run/secrets/kubernetes.io/serviceaccount/ca.crt
S2S_K8S_OIDC_PUBLIC_KEY_PATH=
S2S_RSA_PRIVATE_KEY_PATH=
S2S_RSA_PUBLIC_KEY_PATH=
S2S_RSA_ISSUER=nmc-s2s
S2S_RSA_AUDIENCE=nmc-services

# --- Telegram / Telethon ---
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=CHANGE_ME_TELEGRAM_API_HASH
# Raw Telethon StringSession хранится в зашифрованном session store/vault.
TELEGRAM_SESSION_REF=primary-session
TELEGRAM_RATE_LIMIT_MESSAGES_PER_MINUTE=60

# --- VK API ---
# Raw VK access token хранится только в platform token store/vault.
VK_API_VERSION=5.199
VK_RATE_LIMIT_REQUESTS_PER_SECOND=3
VK_TOKEN_ID=primary

# --- Менеджер секретов (HashiCorp Vault KV v2) ---
VAULT_ENABLED=false
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=CHANGE_ME_VAULT_TOKEN
VAULT_MOUNT=secret
VAULT_PATH=media-center/development
VAULT_TIMEOUT_SECONDS=5

# --- API Gateway ---
API_GATEWAY_RATE_LIMIT=120
API_GATEWAY_RATE_LIMIT_WINDOW_SECONDS=60

# --- Экономика и управление (HITL) ---
COUNCIL_CAP_KV=0.10          # потолок коэффициента влияния Кв
VETO_WINDOW_HOURS=8          # окно вето Совета на выплаты

# --- Платёжный шлюз РФ (HITL) ---
# По умолчанию реальные выплаты выключены. Включайте только после legal/compliance gate.
RF_PAYMENT_GATEWAY_ENABLED=false
RF_PAYMENT_GATEWAY_PROVIDER=rf_payment_gateway
RF_PAYMENT_GATEWAY_BASE_URL=https://payments.example.test/api
RF_PAYMENT_GATEWAY_MERCHANT_ID=CHANGE_ME
RF_PAYMENT_GATEWAY_API_KEY=CHANGE_ME_RF_PAYMENT_GATEWAY_API_KEY
RF_PAYMENT_GATEWAY_EXECUTE_PATH=/payouts
RF_PAYMENT_GATEWAY_STATUS_PATH_TEMPLATE=/payouts/{payment_id}

# --- Приватный блокчейн-аудитор ---
BLOCKCHAIN_AUDITOR_URL=grpc://localhost:50051

# --- Voice-to-Chain ---
VOICE_RAW_AUDIO_TTL_HOURS=24
WHISPER_CPP_BINARY_PATH=whisper-cli
WHISPER_CPP_MODEL_PATH=
WHISPER_CPP_LANGUAGE=ru
WHISPER_CPP_TIMEOUT_SECONDS=300

# --- Наблюдаемость ---
PROMETHEUS_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
